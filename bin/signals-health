#!/usr/bin/env bash
# signals-health — quick API / DB health check wrapper
#
# Usage:
#   bin/signals-health           # all checks
#   bin/signals-health apis      # external APIs + RSS only
#   bin/signals-health db        # PostgreSQL / TimescaleDB only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "${SCRIPT_DIR}/signals-lab" health "$@"
