# signals-lab Environment Variables
# Copy this file to .env and fill in your values

# --------------------------------------------------
# Storage
# --------------------------------------------------
SIGNALSLAB_STORAGE__TIMESERIES__URL=postgresql://postgres:postgres@localhost:5432/signals_ts
SIGNALSLAB_STORAGE__RELATIONAL__URL=postgresql://postgres:postgres@localhost:5432/signals_rel

# --------------------------------------------------
# Data Provider API Keys
# --------------------------------------------------
# Market
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_API_SECRET=your_binance_api_secret

# Social / Sentiment
LUNARCRUSH_API_KEY=your_lunarcrush_api_key

# On-Chain
GLASSNODE_API_KEY=your_glassnode_api_key

# Events / News
NEWSAPI_KEY=your_newsapi_key
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key

# --------------------------------------------------
# API Keys for Downstream Consumers (iHabibi Trading)
# --------------------------------------------------
IHABIBI_API_KEY=sk-yoursecretihabibikey
ADMIN_API_KEY=sk-yourinternaladminkey

# --------------------------------------------------
# Application
# --------------------------------------------------
SIGNALSLAB_APP__ENVIRONMENT=development
SIGNALSLAB_APP__LOG_LEVEL=INFO

# --------------------------------------------------
# NATS (optional event bus)
# --------------------------------------------------
# NATS_URL=nats://localhost:4222